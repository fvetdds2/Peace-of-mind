# Copy to .streamlit/secrets.toml for local dev, or paste into
# Streamlit Community Cloud: App settings -> Secrets.

# Chat assistant provider: "groq" (free, no card) or "anthropic" (paid, usage-based)
PROVIDER = "groq"

# Only needed if PROVIDER = "groq" (default) — free tier, no card
# Get one at https://console.groq.com
GROQ_API_KEY = "gsk_..."

# Only needed if PROVIDER = "anthropic" (https://console.anthropic.com)
# ANTHROPIC_API_KEY = "sk-ant-..."

# OPTIONAL. Powers the "Refresh valuation" button on the Properties tab.
# Leave this out entirely if you'd rather enter Zillow/Redfin/Homes.com
# estimates manually — the button just won't appear.
# Free Developer tier: 50 calls/month, no card required. https://www.rentcast.io/api
# RENTCAST_API_KEY = "..."
