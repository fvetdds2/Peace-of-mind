# Copy to .streamlit/secrets.toml for local dev, or paste into
# Streamlit Community Cloud: App settings -> Secrets.

# Chat assistant provider: "anthropic" or "groq"
PROVIDER = "anthropic"

# Only needed if PROVIDER = "anthropic" (https://console.anthropic.com)
ANTHROPIC_API_KEY = "sk-ant-..."

# Only needed if PROVIDER = "groq", free tier (https://console.groq.com)
GROQ_API_KEY = "gsk_..."

# Powers the "Refresh valuation" button on the Properties tab.
# Free Developer tier: 50 calls/month, no card required.
# https://www.rentcast.io/api
RENTCAST_API_KEY = "..."
